# Configuración de la aplicación
PORT=3000
NODE_ENV=development

# Configuración de JWT (OBLIGATORIA - Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=ejemplo_de_jwt_secret_128_caracteres_aqui_cambia_esto_por_uno_real

# Configuración de base de datos
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nombre_usuario
DB_PASSWORD=contraseña_bdd
DB_NAME=nombre_bdd

# URL de base de datos para producción (opcional)
# DATABASE_URL=postgresql://username:password@host:port/database

# Configuración de Cloudinary
CLOUDINARY_NAME=tu_cloudinary_name
CLOUDINARY_API_KEY=tu_cloudinary_api_key
CLOUDINARY_API_SECRET=tu_cloudinary_api_secret

# Configuración de rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Seguridad HTTP
CORS_ORIGINS=http://localhost:3000
ENABLE_SWAGGER=true

# Esquema y TLS de base de datos
DB_SSL=false
DB_MIGRATIONS_RUN=false

# Usuarios locales de prueba (nunca habilitar en producción)
SEED_TEST_USERS=false
TEST_USER_EMAIL=user@test.local
TEST_USER_PASSWORD=User123!
TEST_ADMIN_EMAIL=admin@test.local
TEST_ADMIN_PASSWORD=Admin123!
